{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/js/(.*)", "destination": "/js/$1" },
    { "source": "/css/(.*)", "destination": "/css/$1" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/((?!admin|js|css|assets|api).*)", "destination": "/index.html" }
  ]
}
